generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Kingdom {
  id         Int         @id @default(autoincrement())
  name       String      @unique @db.VarChar(50)
  color_hex  String      @db.VarChar(10)
  created_at DateTime    @default(now()) @db.Timestamp(0)
  updated_at DateTime    @updatedAt @db.Timestamp(0)
  
  players      Player[]
  territories  Territory[]
  
  // Relations for battles
  attacks    Battle[]    @relation("AttackerKingdom")
  defends    Battle[]    @relation("DefenderKingdom")
}

model Player {
  id              Int       @id @default(autoincrement())
  user_id         Int?      // Nullable in case we don't link to a main user table right away
  username        String    @unique @db.VarChar(50)
  password        String    @db.VarChar(255)
  kingdom_id      Int
  score           Int       @default(0)
  gold            Int       @default(100)
  role            String    @default("MEMBER") @db.VarChar(20)
  
  // Skills System
  atk_level       Int       @default(1)
  def_level       Int       @default(1)
  agi_level       Int       @default(1)
  crit_rate_level Int       @default(1)
  crit_dmg_level  Int       @default(1)
  eco_level       Int       @default(1)
  level           Int       @default(1)
  exp             Int       @default(0)
  skill_points    Int       @default(0)
  stamina         Int       @default(100)
  last_stamina_regen DateTime @default(now()) @db.Timestamp(0)
  energy             Int       @default(100)
  last_energy_regen  DateTime  @default(now()) @db.Timestamp(0)
  wood               Int       @default(0)
  iron               Int       @default(0)
  spices             Int       @default(0)


  created_at      DateTime  @default(now()) @db.Timestamp(0)
  updated_at      DateTime  @updatedAt @db.Timestamp(0)

  kingdom         Kingdom   @relation(fields: [kingdom_id], references: [id])
  movements       PlayerTroopMovement[]
  equipments      Equipment[]
  marketOrders    MarketOrder[]
}

model Territory {
  id           Int       @id @default(autoincrement())
  code         String    @unique @db.VarChar(50) // GADM ID, e.g. IDN.1.1_1
  name         String    @db.VarChar(100)
  kingdom_id   Int?      // Null if neutral
  troops_count Int       @default(0)
  resource_type       String?   @db.VarChar(20)
  resource_expires_at DateTime? @db.Timestamp(0)
  created_at   DateTime  @default(now()) @db.Timestamp(0)
  updated_at   DateTime  @updatedAt @db.Timestamp(0)

  kingdom      Kingdom?  @relation(fields: [kingdom_id], references: [id])
  battles      Battle[]
  movementsTo  PlayerTroopMovement[] @relation("MovementsToTerritory")
  movementsFrom PlayerTroopMovement[] @relation("MovementsFromTerritory")
}

model Battle {
  id                  BigInt    @id @default(autoincrement())
  territory_id        Int
  attacker_kingdom_id Int
  defender_kingdom_id Int?      // Nullable if attacking a neutral territory
  status              String    @db.VarChar(20) // 'ONGOING', 'ATTACKER_WON', 'DEFENDER_WON'
  attacker_troops     Int       @default(0)
  defender_troops     Int       @default(0)
  started_at          DateTime  @default(now()) @db.Timestamp(0)
  ended_at            DateTime? @db.Timestamp(0)

  territory           Territory @relation(fields: [territory_id], references: [id])
  attacker_kingdom    Kingdom   @relation("AttackerKingdom", fields: [attacker_kingdom_id], references: [id])
  defender_kingdom    Kingdom?  @relation("DefenderKingdom", fields: [defender_kingdom_id], references: [id])
}

model PlayerTroopMovement {
  id                BigInt    @id @default(autoincrement())
  player_id         Int
  from_territory_id Int
  to_territory_id   Int
  troops_count      Int
  arrival_time      DateTime  @db.Timestamp(0)
  
  player            Player    @relation(fields: [player_id], references: [id])
  from_territory    Territory @relation("MovementsFromTerritory", fields: [from_territory_id], references: [id])
  to_territory      Territory @relation("MovementsToTerritory", fields: [to_territory_id], references: [id])
}

model Equipment {
  id             Int      @id @default(autoincrement())
  player_id      Int
  name           String   @db.VarChar(100)
  type           String   @db.VarChar(20)  // 'WEAPON', 'ARMOR', 'BOOTS'
  rarity         String   @db.VarChar(20)  // 'COMMON', 'RARE', 'EPIC', 'LEGENDARY'
  atk_bonus      Int      @default(0)
  def_bonus      Int      @default(0)
  agi_bonus      Int      @default(0)
  durability      Int          @default(100)
  max_durability  Int          @default(100)
  sell_price      Int          @default(10)
  equipped        Boolean      @default(false)
  crit_rate_bonus Int          @default(0)
  created_at      DateTime     @default(now()) @db.Timestamp(0)
  on_market       Boolean      @default(false)
  marketOrder     MarketOrder?

  player         Player   @relation(fields: [player_id], references: [id], onDelete: Cascade)
}

model MarketOrder {
  id             Int        @id @default(autoincrement())
  player_id      Int
  item_name      String     @db.VarChar(100)
  rarity         String     @db.VarChar(20)
  item_type      String     @db.VarChar(20) // 'WEAPON', 'HELMET', 'ARMOR', 'ARMS', 'LEG', 'BOOTS'
  order_type     String     @db.VarChar(10) // 'BUY' atau 'SELL'
  price          Int
  equipment_id   Int?       @unique         // Nullable for BUY orders
  created_at     DateTime   @default(now()) @db.Timestamp(0)

  player         Player     @relation(fields: [player_id], references: [id], onDelete: Cascade)
  equipment      Equipment? @relation(fields: [equipment_id], references: [id], onDelete: Cascade)
}

