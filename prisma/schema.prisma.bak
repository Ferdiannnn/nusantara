  store_id          Int
  status_id         Int       @db.SmallInt
  master_product_id Int
  photo             String    @db.VarChar(255)
  created_by        Int
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
}

model product_price {
  id                BigInt    @id @default(autoincrement())
  product_detail_id Int
  role_id           Int
  min_qty           Int
  max_qty           Int?
  price             Int
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
  deleted_at        DateTime? @db.Timestamp(0)
}

model product_property {
  id                BigInt    @id @default(autoincrement())
  product_id        Int
  property_id       Int
  value             String
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
  master_product_id Int       @default(0)
}

model product_type {
  id         BigInt    @id @default(autoincrement())
  name       String    @db.VarChar(50)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model product_type_rule {
  id                 BigInt    @id @default(autoincrement())
  product_type_id    Int
  membership_type_id Int
  created_at         DateTime? @db.Timestamp(0)
  updated_at         DateTime? @db.Timestamp(0)
}

model program {
  id          BigInt    @id @default(autoincrement())
  store_id    Int       @default(0)
  news_id     Int       @default(0)
  name        String    @db.VarChar(50)
  description String    @default("")
  icon        String    @default("") @db.VarChar(255)
  start_date  DateTime  @db.Date
  end_date    DateTime  @db.Date
  is_active   Boolean   @default(false)
  created_at  DateTime? @db.Timestamp(0)
  updated_at  DateTime? @db.Timestamp(0)
}

model program_condition {
  id                      BigInt    @id @default(autoincrement())
  program_id              Int
  program_condition_type  String    @db.VarChar(50)
  master_product_id       Int?
  min_qty                 Int?
  min_amount              Decimal?  @db.Decimal(12, 2)
  max_discount_percentage Decimal?  @db.Decimal(5, 2)
  role_id                 Int?
  calculation_type        String    @default("NONE") @db.VarChar(50)
  accumulation_type       String    @default("NONE") @db.VarChar(50)
  created_at              DateTime? @db.Timestamp(0)
  updated_at              DateTime? @db.Timestamp(0)
  order_channel           String    @default("ALL") @db.VarChar(50)
  max_qty                 Int?
  max_amount              Decimal?  @db.Decimal(12, 2)
}

model program_product {
  id                BigInt    @id @default(autoincrement())
  program_id        Int
  master_product_id Int
  is_active         Boolean   @default(false)
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
}

model program_reward {
  id                  BigInt    @id @default(autoincrement())
  program_id          Int
  program_reward_type String    @db.VarChar(50)
  value               Decimal?  @db.Decimal(12, 2)
  max_value           Decimal?  @db.Decimal(12, 2)
  point               Int?
  free_product_id     Int?
  free_product_qty    Int?
  calculation_type    String    @default("NONE") @db.VarChar(50)
  is_repeatable       Boolean   @default(false)
  created_at          DateTime? @db.Timestamp(0)
  updated_at          DateTime? @db.Timestamp(0)
  min_qty             Int?
  min_amount          Decimal?  @db.Decimal(12, 2)
  point_type_id       Int?      @default(0)
}

model property {
  id         BigInt    @id @default(autoincrement())
