  user_id    Int
  keyword    String    @db.VarChar(255)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model user_store {
  id                   BigInt    @id @default(autoincrement())
  user_id              Int
  store_id             Int
  user_store_status_id Int       @default(1) @db.SmallInt
  created_at           DateTime? @db.Timestamp(0)
  updated_at           DateTime? @db.Timestamp(0)
  role_id              Int       @default(3)
  code                 String    @default("") @db.VarChar(50)
  reference_id         Int       @default(0)
}

model users {
  id                BigInt    @id @default(autoincrement())
  name              String    @db.VarChar(255)
  email             String    @unique(map: "users_email_unique") @db.VarChar(255)
  email_verified_at DateTime? @db.Timestamp(0)
  password          String    @db.VarChar(255)
  remember_token    String?   @db.VarChar(100)
  role_id           Int
  photo             String?   @db.VarChar(255)
  phone             String?   @db.VarChar(30)
  phone_verified_at DateTime? @db.Timestamp(0)
  date_of_birth     DateTime? @db.Date
  store_id          BigInt?
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
  deleted_at        DateTime? @db.Timestamp(0)
  code              String    @default("") @db.VarChar(50)
  created_by        Int       @default(0)
  updated_by        Int       @default(0)
  national_id       String    @default("") @db.VarChar(20)
  store             store?    @relation(fields: [store_id], references: [id])
}

model warehouse {
  id         BigInt    @id @default(autoincrement())
  store_id   Int
  name       String    @db.VarChar(255)
  reference  String?   @db.VarChar(50)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
  user_id    Int       @default(0)
}

model wishlist {
  id         BigInt    @id @default(autoincrement())
  user_id    Int
  product_id Int
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}
