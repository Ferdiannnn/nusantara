  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model stock_opname {
  id         BigInt    @id @default(autoincrement())
  store_id   Int
  name       String    @db.VarChar(50)
  start_date DateTime  @db.Date
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
  deleted_at DateTime? @db.Timestamp(0)
  is_active  Boolean   @default(false)
}

model stock_opname_detail {
  id                BigInt    @id @default(autoincrement())
  stock_opname_id   Int
  product_detail_id Int
  product_batch_id  Int
  warehouse_id      Int
  qty               Int
  batch_number      String?   @db.VarChar(50)
  created_by        Int
  updated_by        Int
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
  deleted_at        DateTime? @db.Timestamp(0)
}

model store {
  id                BigInt    @id @default(autoincrement())
  name              String    @db.VarChar(50)
  address           String
  postcode          String    @db.VarChar(5)
  geocoding_address String
  latitude          Decimal   @db.Decimal(10, 8)
  longitude         Decimal   @db.Decimal(11, 8)
  photo             String?   @db.VarChar(255)
  email             String?   @db.VarChar(255)
  phone             String?   @db.VarChar(255)
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
  deleted_at        DateTime? @db.Timestamp(0)
  city_id           Int       @default(1)
  is_active         Boolean   @default(false)
  company_id        Int       @default(0)
  attendance_radius Int       @default(0)
  users             users[]
}

model store_address {
  id         BigInt    @id @default(autoincrement())
  store_id   Int
  name       String    @db.VarChar(50)
  address    String
  urban_id   Int
  postcode   String    @db.VarChar(5)
  latitude   Decimal   @db.Decimal(10, 8)
  longitude  Decimal   @db.Decimal(11, 8)
  phone      String    @db.VarChar(30)
  is_primary Boolean
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
  deleted_at DateTime? @db.Timestamp(0)
  note       String    @default("")
}

model store_balance {
  id                BigInt    @id @default(autoincrement())
  store_id          Int
  reference_id      Int?
  balance_type_id   Int
  key               String    @db.VarChar(50)
  amount            Int
  balance_status_id Int       @db.SmallInt
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
}

model store_hour {
  id             BigInt    @id @default(autoincrement())
  store_id       Int
  day_of_week_id Int       @db.SmallInt
  start_time     DateTime  @db.Time(0)
  end_time       DateTime  @db.Time(0)
  created_at     DateTime? @db.Timestamp(0)
  updated_at     DateTime? @db.Timestamp(0)
}

model summary_product_best_seller {
  id                BigInt    @id @default(autoincrement())
  store_id          Int
  master_product_id Int
  product_id        Int
  product_detail_id Int
  period_type_id    Int       @db.SmallInt
  total_sold        BigInt
  last_sold_at      DateTime  @db.Date
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
  sold_frequency    Int       @default(0)
  total_customer    Int       @default(0)
}

model tax_invoice_serial_number {
  id           BigInt    @id @default(autoincrement())
  store_id     Int
  start_number String    @db.VarChar(255)
  end_number   String    @db.VarChar(255)
  is_active    Boolean   @default(false)
  created_at   DateTime? @db.Timestamp(0)
  updated_at   DateTime? @db.Timestamp(0)
}

model tax_invoice_serial_number_detail {
  id                           BigInt    @id @default(autoincrement())
  tax_invoice_serial_number_id Int
  reference_number             String    @db.VarChar(255)
  created_at                   DateTime? @db.Timestamp(0)
  updated_at                   DateTime? @db.Timestamp(0)
  serial_number                String    @default("") @db.VarChar(255)
}

model telescope_entries {
  sequence                BigInt                   @id @default(autoincrement())
  uuid                    String                   @unique(map: "telescope_entries_uuid_unique") @db.Uuid
  batch_id                String                   @db.Uuid
  family_hash             String?                  @db.VarChar(255)
  should_display_on_index Boolean                  @default(true)
  type                    String                   @db.VarChar(20)
  content                 String
  created_at              DateTime?                @db.Timestamp(0)
  telescope_entries_tags  telescope_entries_tags[]

  @@index([batch_id], map: "telescope_entries_batch_id_index")
  @@index([created_at], map: "telescope_entries_created_at_index")
  @@index([family_hash], map: "telescope_entries_family_hash_index")
  @@index([type, should_display_on_index], map: "telescope_entries_type_should_display_on_index_index")
}

model telescope_entries_tags {
  entry_uuid        String            @db.Uuid
  tag               String            @db.VarChar(255)
  telescope_entries telescope_entries @relation(fields: [entry_uuid], references: [uuid], onDelete: Cascade, onUpdate: NoAction, map: "telescope_entries_tags_entry_uuid_foreign")

  @@id([entry_uuid, tag])
  @@index([tag], map: "telescope_entries_tags_tag_index")
}

model telescope_monitoring {
  tag String @id @db.VarChar(255)
}

model tracking {
  id                 BigInt    @id @default(autoincrement())
  order_id           Int
  ship_detail_id     Int
  airway_bill_number String    @db.VarChar(50)
  history            String?
  delivery           String?
  payload            String?
  created_at         DateTime? @db.Timestamp(0)
  updated_at         DateTime? @db.Timestamp(0)
}

