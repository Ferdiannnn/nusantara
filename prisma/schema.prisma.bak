generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model accurate {
  id                 BigInt    @id @default(autoincrement())
  store_id           Int
  client_id          String    @db.VarChar(50)
  client_secret      String    @db.VarChar(50)
  url_oauth_callback String    @db.VarChar(255)
  authorization_code String    @db.VarChar(50)
  database_id        Int
  host               String    @db.VarChar(255)
  session            String    @db.VarChar(50)
  created_at         DateTime? @db.Timestamp(0)
  updated_at         DateTime? @db.Timestamp(0)
}

model accurate_log {
  id                     BigInt    @id @default(autoincrement())
  key                    String    @db.VarChar(50)
  payload                String?
  created_at             DateTime? @db.Timestamp(0)
  updated_at             DateTime? @db.Timestamp(0)
  store_id               Int       @default(0)
  accurate_log_status_id Int       @default(0)
}

model accurate_token {
  id            BigInt    @id @default(autoincrement())
  accurate_id   Int
  name          String    @db.VarChar(50)
  email         String    @db.VarChar(50)
  access_token  String    @db.VarChar(50)
  refresh_token String    @db.VarChar(50)
  scope         String
  created_at    DateTime? @db.Timestamp(0)
  updated_at    DateTime? @db.Timestamp(0)
}

model attendance {
  id                   BigInt    @id @default(autoincrement())
  store_id             Int
  user_id              Int
  attendance_status_id Int       @default(1) @db.SmallInt
  attendance_time      DateTime  @db.Timestamp(0)
  photo                String    @db.VarChar(255)
  latitude             Decimal   @db.Decimal(10, 8)
  longitude            Decimal   @db.Decimal(11, 8)
  created_at           DateTime? @db.Timestamp(0)
  updated_at           DateTime? @db.Timestamp(0)
}

model bank_account {
  id         BigInt    @id @default(autoincrement())
  store_id   Int
  type       String    @db.VarChar(50)
  number     String    @db.VarChar(30)
  name       String    @db.VarChar(50)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model bca_notification {
  id               BigInt    @id @default(autoincrement())
  company_code     String    @db.VarChar(10)
  customer_number  String    @db.VarChar(30)
  request_id       String    @db.VarChar(50)
  channel_type     String    @db.VarChar(10)
  customer_name    String    @db.VarChar(50)
  currency_code    String    @db.VarChar(10)
  paid_amount      String    @db.VarChar(30)
  total_amount     String    @db.VarChar(30)
  sub_company      String?   @db.VarChar(10)
  transaction_date String    @db.VarChar(30)
  reference        String?   @db.VarChar(30)
  detail_bills     String?
  flag_advice      String    @db.VarChar(10)
  additional_data  String?
  created_at       DateTime? @db.Timestamp(0)
  updated_at       DateTime? @db.Timestamp(0)
}

model broadcast_message {
  id                        BigInt    @id @default(autoincrement())
  broadcast_message_type_id Int       @db.SmallInt
  title                     String    @db.VarChar(50)
  message                   String
  payload                   String?
  created_at                DateTime? @db.Timestamp(0)
  updated_at                DateTime? @db.Timestamp(0)
  content                   String?
  photo                     String?   @db.VarChar(255)
}

model cart {
  id                BigInt    @id @default(autoincrement())
  user_id           Int
  product_detail_id Int
  qty               Int
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
  price             Int       @default(0)
  note              String    @default("")
  store_id          Int       @default(0)
  sales_id          Int       @default(0)
}

model category {
  id         BigInt    @id @default(autoincrement())
  name       String    @db.VarChar(50)
  photo      String?   @db.VarChar(255)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
  deleted_at DateTime? @db.Timestamp(0)
  sequence   Int       @default(0)
}

model city {
  id          BigInt    @id @default(autoincrement())
  province_id Int
  name        String    @db.VarChar(50)
  created_at  DateTime? @db.Timestamp(0)
  updated_at  DateTime? @db.Timestamp(0)
}

model company {
  id         BigInt    @id @default(autoincrement())
  name       String    @db.VarChar(50)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model config {
  id             BigInt    @id @default(autoincrement())
  key            String    @db.VarChar(50)
  value          String
  created_at     DateTime? @db.Timestamp(0)
  updated_at     DateTime? @db.Timestamp(0)
  config_type_id Int       @default(0)
  store_id       Int       @default(0)
}

model country {
  id         BigInt    @id @default(autoincrement())
  name       String    @db.VarChar(50)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model delivery_order {
  id                    BigInt    @id @default(autoincrement())
  order_id              Int
  delivery_order_number String    @db.VarChar(10)
  reference             String?   @db.VarChar(50)
  created_at            DateTime? @db.Timestamp(0)
  updated_at            DateTime? @db.Timestamp(0)
  reference_id          Int       @default(0)
  reference_date        DateTime? @db.Date
  reference_shipment    String?   @db.VarChar(50)
}

model delivery_order_detail {
  id                 BigInt    @id @default(autoincrement())
  delivery_order_id  Int
  order_detail_id    Int
  product_detail_id  Int
  product_batch_id   Int
  qty                Int
  created_at         DateTime? @db.Timestamp(0)
  updated_at         DateTime? @db.Timestamp(0)
  batch_number       String?   @db.VarChar(50)
  warehouse_name     String?   @db.VarChar(50)
  reference_price    Int       @default(0)
  reference_discount Decimal   @default(0) @db.Decimal(8, 5)
}

model district {
  id         BigInt    @id @default(autoincrement())
  city_id    Int
  name       String    @db.VarChar(50)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model district_anteraja {
  id          BigInt    @id @default(autoincrement())
  district_id Int
  code        String    @db.VarChar(10)
  created_at  DateTime? @db.Timestamp(0)
  updated_at  DateTime? @db.Timestamp(0)
}

model employee_visit {
  id                       BigInt    @id @default(autoincrement())
  store_id                 Int
  user_id                  Int
  employee_visit_type_id   Int       @default(1) @db.SmallInt
  employee_visit_status_id Int       @default(1) @db.SmallInt
  customer_id              Int       @default(0)
  attendance_time          DateTime  @db.Timestamp(0)
  photo                    String    @db.VarChar(255)
  latitude                 Decimal   @db.Decimal(10, 8)
  longitude                Decimal   @db.Decimal(11, 8)
  created_at               DateTime? @db.Timestamp(0)
  updated_at               DateTime? @db.Timestamp(0)
}

model failed_jobs {
  id         BigInt   @id @default(autoincrement())
  uuid       String   @unique(map: "failed_jobs_uuid_unique") @db.VarChar(255)
  connection String
  queue      String
  payload    String
  exception  String
  failed_at  DateTime @default(now()) @db.Timestamp(0)
}

model fcm_token {
  id         BigInt    @id @default(autoincrement())
  user_id    Int
  token      String    @unique(map: "fcm_token_token_unique") @db.VarChar(255)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model info {
  id         BigInt    @id @default(autoincrement())
  key        String    @db.VarChar(50)
  value      String
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model invoice {
  id                       BigInt    @id @default(autoincrement())
  order_id                 Int
  delivery_id              Int
  user_id                  Int
  invoice_number           String    @db.VarChar(10)
  total                    Int
  due_date                 DateTime? @db.Date
  invoice_status_id        Int       @db.SmallInt
  reference                String?   @db.VarChar(255)
  note                     String?
  created_at               DateTime? @db.Timestamp(0)
  updated_at               DateTime? @db.Timestamp(0)
  reference_date           DateTime? @db.Date
  reference_total          Decimal?  @db.Decimal(18, 6)
  reference_owing          Decimal?  @db.Decimal(18, 6)
  store_id                 Int       @default(0)
  is_purchase_order_exists Boolean   @default(false)
}

model invoice_detail {
  id                BigInt    @id @default(autoincrement())
  invoice_id        Int
  order_detail_id   Int
  product_detail_id Int
  qty               Int
  price             Int
  subtotal          Int
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
  reference         String?   @db.VarChar(50)
}

model item_transfer {
  id                      BigInt    @id @default(autoincrement())
  store_id                Int
  item_transfer_status_id Int       @default(1) @db.SmallInt
  product_batch_id        Int
  warehouse_id            Int
  qty                     Int
  created_by              Int
  updated_by              Int
  created_at              DateTime? @db.Timestamp(0)
  updated_at              DateTime? @db.Timestamp(0)
}

model jobs {
  id           BigInt @id @default(autoincrement())
  queue        String @db.VarChar(255)
  payload      String
  attempts     Int    @db.SmallInt
  reserved_at  Int?
  available_at Int
  created_at   Int

  @@index([queue], map: "jobs_queue_index")
}

model limit {
  id         BigInt    @id @default(autoincrement())
  store_id   Int
  name       String    @db.VarChar(50)
  limit      BigInt
  period     Int
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model log {
  id            BigInt    @id @default(autoincrement())
  store_id      Int
  log_status_id Int       @db.SmallInt
  key           String    @db.VarChar(50)
  description   String    @default("") @db.VarChar(255)
  payload       String?
  created_at    DateTime? @db.Timestamp(0)
  updated_at    DateTime? @db.Timestamp(0)
}

model master_product {
  id              BigInt    @id @default(autoincrement())
  category_id     Int
  product_type_id Int       @default(1) @db.SmallInt
  name            String    @db.VarChar(100)
  description     String
  weight          Int
  tags            String
  created_at      DateTime? @db.Timestamp(0)
  updated_at      DateTime? @db.Timestamp(0)
  deleted_at      DateTime? @db.Timestamp(0)
  principal_id    Int       @default(0)
  sku             String    @default("") @db.VarChar(50)
  nie             String    @default("") @db.VarChar(50)
  nie_date        DateTime? @db.Date
  initial_price   Int       @default(0)
}

model membership {
  id                      BigInt    @id @default(autoincrement())
  user_id                 Int
  membership_status_id    Int
  message                 String
  nama_relasi             String    @db.VarChar(50)
  alamat_relasi           String
  nomor_ijin_apotek       String    @db.VarChar(250)
  masa_berlaku_ijin       DateTime? @db.Date
  nomor_sertifikat_cdob   String    @db.VarChar(250)
  masa_berlaku_sertifikat DateTime? @db.Date
  nomor_nib               String    @db.VarChar(50)
  kode_sipnap             String    @db.VarChar(50)
  nama_apoteker_pj        String    @db.VarChar(100)
  alamat_tinggal_apj      String
  nomor_sika              String    @db.VarChar(250)
  masa_berlaku_sika       DateTime? @db.Date
  nama_ttk_1              String    @db.VarChar(50)
  nomor_sittk_1           String    @db.VarChar(50)
  nama_ttk_2              String    @db.VarChar(50)
  nomor_sittk_2           String    @db.VarChar(50)
  specimen                String    @db.VarChar(255)
  document                String    @db.VarChar(255)
  created_at              DateTime? @db.Timestamp(0)
  updated_at              DateTime? @db.Timestamp(0)
  membership_type_id      Int       @default(1) @db.SmallInt
  file_siup               String?   @db.VarChar(255)
  file_nib                String?   @db.VarChar(255)
  file_ijin               String?   @db.VarChar(255)
  file_sipa               String?   @db.VarChar(255)
  file_cdob               String?   @db.VarChar(255)
  file_npwp               String?   @db.VarChar(255)
  file_ktp_apj            String?   @db.VarChar(255)
  file_ktp_pj             String?   @db.VarChar(255)
  file_sipttk             String?   @db.VarChar(255)
  npwp                    String    @default("") @db.VarChar(50)
}

model membership_type {
  id         BigInt    @id @default(autoincrement())
  name       String    @db.VarChar(50)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model menu {
  id         BigInt    @id @default(autoincrement())
  name       String    @unique(map: "menu_name_unique") @db.VarChar(50)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
  key        String    @default("") @db.VarChar(255)
  sequence   Int       @default(0)
}

model midtrans_notification {
  id                 BigInt    @id @default(autoincrement())
  va_number          String?   @db.VarChar(50)
  transaction_type   String?   @db.VarChar(50)
  transaction_time   DateTime  @db.Timestamp(0)
  transaction_status String    @db.VarChar(50)
  transaction_id     String    @db.VarChar(50)
  store              String?   @db.VarChar(50)
  status_message     String    @db.VarChar(50)
  status_code        Int
  signature_key      String    @db.VarChar(255)
  settlement_time    DateTime? @db.Timestamp(0)
  payment_type       String    @db.VarChar(50)
  payment_code       String?   @db.VarChar(50)
  order_id           String    @db.VarChar(50)
  merchant_id        String    @db.VarChar(50)
  masked_card        String?   @db.VarChar(50)
  issuer             String?   @db.VarChar(50)
  gross_amount       String    @db.VarChar(50)
  fraud_status       String    @db.VarChar(50)
  currency           String    @db.VarChar(50)
  card_type          String?   @db.VarChar(50)
  bank               String?   @db.VarChar(50)
  approval_code      String?   @db.VarChar(50)
  acquirer           String?   @db.VarChar(50)
  biller_code        String?   @db.VarChar(50)
  bill_key           String?   @db.VarChar(50)
  created_at         DateTime? @db.Timestamp(0)
  updated_at         DateTime? @db.Timestamp(0)
  url                String?   @db.VarChar(255)
  deeplink           String?   @db.VarChar(255)
}

model migrations {
  id        Int    @id @default(autoincrement())
  migration String @db.VarChar(255)
  batch     Int
}

model news {
  id         BigInt    @id @default(autoincrement())
  title      String
  content    String
  thumbnail  String    @db.VarChar(255)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
  store_id   Int       @default(0)
  is_active  Boolean   @default(false)
}

model notification {
  id         BigInt    @id @default(autoincrement())
  user_id    Int
  title      String    @db.VarChar(50)
  message    String    @db.VarChar(255)
  payload    String?
  is_read    Int       @db.SmallInt
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model odoo {
  id           BigInt    @id @default(autoincrement())
  store_id     Int
  url_oauth    String    @db.VarChar(255)
  db           String    @db.VarChar(50)
  login        String    @db.VarChar(50)
  password     String    @db.VarChar(255)
  url_web      String    @db.VarChar(255)
  session      String    @db.VarChar(255)
  created_at   DateTime? @db.Timestamp(0)
  updated_at   DateTime? @db.Timestamp(0)
  company_id   Int       @default(0)
  database_id  Int       @default(0)
  access_token String    @default("") @db.VarChar(255)
}

model odoo_log {
  id                 BigInt    @id @default(autoincrement())
  store_id           Int
  odoo_log_status_id Int       @db.SmallInt
  key                String    @db.VarChar(50)
  payload            String?
  created_at         DateTime? @db.Timestamp(0)
  updated_at         DateTime? @db.Timestamp(0)
  response           String?
}

model order {
  id                  BigInt    @id @default(autoincrement())
  user_id             Int
  store_id            Int
  order_status_id     Int
  order_number        String    @db.VarChar(10)
  total               Int
  note                String?
  created_at          DateTime? @db.Timestamp(0)
  updated_at          DateTime? @db.Timestamp(0)
  deleted_at          DateTime? @db.Timestamp(0)
  message             String    @default("")
  sales_id            Int       @default(0)
  payment_type_id     Int       @default(0)
  is_pending          Boolean   @default(false)
  reference           String?   @db.VarChar(255)
  purchase_order_file String?   @db.VarChar(255)
  created_by          Int       @default(0)
  updated_by          Int       @default(0)
}

model order_detail {
  id                BigInt    @id @default(autoincrement())
  order_id          Int
  product_detail_id Int
  qty               Int
  price             Int
  subtotal          Int
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
  initial_price     Int       @default(0)
  note              String    @default("")
  is_bonus          Boolean   @default(false)
}

model order_finish {
  id                       BigInt    @id @default(autoincrement())
  order_id                 Int
  photo                    String?   @db.VarChar(100)
  driver_response_status   Int?
  customer_response_status Int?
  created_at               DateTime? @db.Timestamp(0)
  updated_at               DateTime? @db.Timestamp(0)
}

model order_invoice {
  id                BigInt    @id @default(autoincrement())
  order_id          Int
  service_detail_id Int
  weight            Float
  quantity          Int
  total             Int
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
}

model order_pending {
  id                BigInt    @id @default(autoincrement())
  order_id          Int
  order_detail_id   Int
  pending_type_id   Int       @db.SmallInt
  product_detail_id Int
  qty               Int
  note              String?
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
}

model order_status {
  id          Int       @id
  name        String    @db.VarChar(50)
  description String
  created_at  DateTime? @db.Timestamp(0)
  updated_at  DateTime? @db.Timestamp(0)
}

model order_unread_message {
  order_id Int
  user_id  Int

  @@id([order_id, user_id])
}

model otp {
  id         BigInt    @id @default(autoincrement())
  user_id    Int
  otp        String    @db.VarChar(8)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model password_resets {
  email      String    @db.VarChar(255)
  token      String    @db.VarChar(255)
  created_at DateTime? @db.Timestamp(0)

  @@index([email], map: "password_resets_email_index")
  @@ignore
}

model payment {
  id                BigInt    @id @default(autoincrement())
  user_id           Int
  order_id          Int
  amount            Int
  point             Int
  payment_status_id Int       @db.SmallInt
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
  payment_type_id   Int       @default(1) @db.SmallInt
  due_date          DateTime? @db.Date
  charge            Int       @default(0)
  invoice_id        Int       @default(0)
  reference_number  String?   @db.VarChar(50)
  reference_date    DateTime? @db.Date
  payment_number    String    @default("") @db.VarChar(10)
  store_id          Int       @default(0)
  created_by        Int       @default(0)
}

model payment_invoice {
  id         BigInt    @id @default(autoincrement())
  payment_id Int
  invoice_id Int
  amount     Decimal   @default(0) @db.Decimal(18, 6)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model permission {
  id         BigInt    @id @default(autoincrement())
  name       String    @unique(map: "permission_name_unique") @db.VarChar(50)
  created_at DateTime? @db.Timestamp(0)
  updated_at DateTime? @db.Timestamp(0)
}

model personal_access_tokens {
  id             BigInt    @id @default(autoincrement())
  tokenable_type String    @db.VarChar(255)
  tokenable_id   BigInt
  name           String    @db.VarChar(255)
  token          String    @unique(map: "personal_access_tokens_token_unique") @db.VarChar(64)
  abilities      String?
  last_used_at   DateTime? @db.Timestamp(0)
  created_at     DateTime? @db.Timestamp(0)
  updated_at     DateTime? @db.Timestamp(0)

  @@index([tokenable_type, tokenable_id], map: "personal_access_tokens_tokenable_type_tokenable_id_index")
}

model price_history {
  id                BigInt    @id @default(autoincrement())
  store_id          Int
  product_id        Int
  product_detail_id Int
  product_price_id  Int
  role_id           Int
  min_qty           Int
  old_price         Int
  new_price         Int
  created_by        Int
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
}

model pricelist {
  id                  BigInt    @id @default(autoincrement())
  store_id            Int
  name                String    @db.VarChar(50)
  is_active           Boolean   @default(true)
  created_at          DateTime? @db.Timestamp(0)
  updated_at          DateTime? @db.Timestamp(0)
  deleted_at          DateTime? @db.Timestamp(0)
  reference           String?   @db.VarChar(255)
  include_all_product Boolean   @default(false)
}

model pricelist_detail {
  id                BigInt    @id @default(autoincrement())
  pricelist_id      Int
  product_detail_id Int
  min_qty           Int       @default(1)
  price_type        Int       @default(1) @db.SmallInt
  price             Decimal   @db.Decimal(12, 2)
  start_date        DateTime? @db.Date
  end_date          DateTime? @db.Date
  is_active         Boolean   @default(true)
  updated_by        Int
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
  deleted_at        DateTime? @db.Timestamp(0)
}

model principal {
  id              BigInt    @id @default(autoincrement())
  code            String    @db.VarChar(50)
  name            String    @db.VarChar(50)
  created_at      DateTime? @db.Timestamp(0)
  updated_at      DateTime? @db.Timestamp(0)
  is_global_price Boolean   @default(false)
}

model product {
  id                BigInt    @id @default(autoincrement())
  store_id          Int
  category_id       Int
  product_type_id   Int       @default(1) @db.SmallInt
  name              String    @db.VarChar(100)
  description       String
  sku               String?   @db.VarChar(50)
  weight            Int
  point             Int       @default(0)
  is_active         Boolean
  updated_by        Int
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
  deleted_at        DateTime? @db.Timestamp(0)
  master_product_id Int       @default(0)
}

model product_batch {
  id                BigInt    @id @default(autoincrement())
  product_detail_id Int
  batch_number      String    @db.VarChar(50)
  qty               Int
  expired_date      DateTime  @db.Date
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
  store_id          Int       @default(0)
  warehouse_id      Int       @default(0)
  reference         String?   @db.VarChar(50)
}

model product_detail {
  id            BigInt    @id @default(autoincrement())
  product_id    Int
  name          String    @db.VarChar(50)
  sku           String?   @db.VarChar(50)
  stock         Int
  created_at    DateTime? @db.Timestamp(0)
  updated_at    DateTime? @db.Timestamp(0)
  deleted_at    DateTime? @db.Timestamp(0)
  initial_price Int       @default(0)
  cost_price    Decimal   @default(0) @db.Decimal(15, 6)
}

model product_dimension {
  id                BigInt    @id @default(autoincrement())
  master_product_id Int
  length            Decimal   @default(0) @db.Decimal(10, 2)
  width             Decimal   @default(0) @db.Decimal(10, 2)
  height            Decimal   @default(0) @db.Decimal(10, 2)
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
}

model product_image {
  id                BigInt    @id @default(autoincrement())
  product_id        Int
  photo             String    @db.VarChar(255)
  sequence          Int
  created_at        DateTime? @db.Timestamp(0)
  updated_at        DateTime? @db.Timestamp(0)
  master_product_id Int       @default(0)
}

model product_image_request {
